# Database (PostgreSQL connection string)
DATABASE_URL=postgresql://user:password@localhost:5432/serendipity_stream

# JWT secret for auth tokens (use a long random string in production)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Optional: base URL for server-side API calls (defaults to http://localhost:3000)
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Phase 2 - TURN server (production)
# TURN_URL=turn:your-turn.example.com:3478
# TURN_USERNAME=user
# TURN_PASSWORD=secret
