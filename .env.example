# Database (PostgreSQL connection string)
DATABASE_URL=postgresql://user:password@localhost:5432/serendipity_stream

# JWT secret for auth tokens (use a long random string in production)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
# Optional dedicated signer for email verification links (falls back to JWT_SECRET if omitted)
# EMAIL_VERIFICATION_SECRET=your-email-verification-secret

# Optional: base URL for server-side API calls (defaults to http://localhost:3000)
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Comma-separated list of allowed frontend origins for Socket.io CORS in production
# SOCKET_CORS_ORIGIN=https://your-frontend.example.com

# Set to false only if HTTPS is terminated before this process and requests are always trusted
# ENFORCE_HTTPS=true

# SMTP email verification
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your_smtp_username
# SMTP_PASS=your_smtp_password
# EMAIL_FROM=no-reply@your-domain.com

# Phase 2 - TURN server (production)
# NEXT_PUBLIC_TURN_URL=turn:your-turn.example.com:3478,turns:your-turn.example.com:5349
# NEXT_PUBLIC_TURN_USERNAME=user
# NEXT_PUBLIC_TURN_PASSWORD=secret

# Image upload (Cloudflare R2 / S3 compatible)
# R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# IMPORTANT: use account endpoint only (do not append bucket name/path)
# R2_ACCESS_KEY_ID=your-r2-access-key-id
# R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# R2_BUCKET_NAME=your-bucket-name
# Optional public base URL for generated file links
# R2_PUBLIC_URL=https://cdn.yourdomain.com
